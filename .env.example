# --- Database (PostgreSQL) ---
# Instant free DB: `npx create-db` (Prisma Postgres, claim it to keep it)
# or any Postgres (Neon, Supabase, self-hosted):
DATABASE_URL="postgres://user:pass@host:5432/db?sslmode=require"

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"
AUTH_TRUST_HOST=true

# --- AI (Phase 1.5 — OFF by default; enable only with fake/demo data
#     until a DPA-backed, zero-retention EU provider is locked in) ---
ENABLE_AI_FEATURES=false
AI_PROVIDER=""
AI_BASE_URL=""
AI_API_KEY=""
AI_MODEL=""

# --- Storage ---
# Local disk root for uploaded documents (ephemeral on Vercel — demo only)
# STORAGE_ROOT=

# --- Phase 2 placeholders (do not implement yet) ---
# MYDATA_PROVIDER_API_KEY=
# OSDDY_INTEGRATION_URL=
